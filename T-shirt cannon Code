const int IN1 = 8;
const int IN2 = 9;

void setup() {
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
}

void openValve() {
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  delay(250);            // Pulse to latch open
  digitalWrite(IN1, LOW); // Turn off to save battery
}

void closeValve() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  delay(250);            // Pulse to latch closed
  digitalWrite(IN2, LOW); // Turn off to save battery
}

void loop() {
  openValve();
  delay(5000); // Stay open for 5 seconds
  closeValve();
  delay(5000); // Stay closed for 5 seconds
}
